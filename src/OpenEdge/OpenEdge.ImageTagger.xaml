<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenEdge.ImageTagger"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      Title="ImageTagger"
      Background="#FF101014"
      mc:Ignorable="d">
  <Page.Resources>
    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Margin" Value="3" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="Foreground" Value="#FFEDEDED" />
      <Setter Property="Background" Value="#66303030" />
      <Setter Property="BorderBrush" Value="#668A6AB0" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
  </Page.Resources>
  <Grid x:Name="imageTaggerBottom" Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="420" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="430" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0"
            Grid.ColumnSpan="3"
            Margin="0,0,0,12"
            Padding="10"
            CornerRadius="10"
            Background="#E0161616"
            BorderBrush="#448A6AB0"
            BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="Tag Media"
                   Foreground="White"
                   FontSize="24"
                   FontFamily="Times New Roman"
                   VerticalAlignment="Center" />
        <Button x:Name="pathOfFile"
                Grid.Column="1"
                Margin="16,0"
                Padding="10,6"
                Background="#55222222"
                BorderBrush="#448A6AB0"
                Content=""
                Foreground="#FFEDEDED"
                FontSize="14"
                FontFamily="Times New Roman"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Click="pathOfFile_Click" />
        <Label x:Name="forcedAmountLabel"
               Grid.Column="2"
               Foreground="#FFFF6B6B"
               FontSize="16"
               FontWeight="Bold"
               VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Border x:Name="BrowsePanel"
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,0,12,0"
            Padding="12"
            CornerRadius="10"
            Background="#E0141418"
            BorderBrush="#338A6AB0"
            BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Browse media"
                   Foreground="White"
                   FontSize="18"
                   FontFamily="Times New Roman"
                   Margin="0,0,0,8" />
        <ContentControl x:Name="MediaBrowserHost"
                        Grid.Row="1" />
      </Grid>
    </Border>

    <Border x:Name="PreviewPanel"
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,0,12,0"
            Padding="12"
            CornerRadius="10"
            Background="#E0141418"
            BorderBrush="#338A6AB0"
            BorderThickness="1">
      <Grid>
        <Image x:Name="heartbg"
               Source="/heartsbgblack.png"
               Stretch="UniformToFill"
               Opacity="0.65" />
        <Image x:Name="bgOfImage"
               Visibility="Collapsed"
               IsHitTestVisible="False" />
        <MediaElement x:Name="currentVideoBg"
                      Visibility="Collapsed"
                      IsHitTestVisible="False"
                      IsMuted="True">
          <UIElement.Effect>
            <BlurEffect x:Name="mediaBlurEffect"
                        Radius="0"
                        KernelType="Gaussian" />
          </UIElement.Effect>
        </MediaElement>
        <Image x:Name="currentImage"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
        <MediaElement x:Name="currentVideo"
                      Stretch="Uniform"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Visibility="Collapsed"
                      MediaOpened="currentVideo_MediaOpened"
                      MediaEnded="currentVideo_MediaEnded"
                      MediaFailed="currentVideo_MediaFailed" />
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="2"
            Padding="12"
            CornerRadius="10"
            Background="#E0141418"
            BorderBrush="#338A6AB0"
            BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Tags"
                   Foreground="White"
                   FontSize="18"
                   FontFamily="Times New Roman"
                   Margin="0,0,0,8" />
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
          <WrapPanel x:Name="TagCategoryPanel"
                     Orientation="Horizontal" />
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Grid.ColumnSpan="3"
            Margin="0,10,0,0"
            Padding="8"
            CornerRadius="10"
            Background="#E0161616"
            BorderBrush="#448A6AB0"
            BorderThickness="1">
      <Border.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
          <Setter Property="MinHeight" Value="30" />
          <Setter Property="MinWidth" Value="82" />
          <Setter Property="Margin" Value="3" />
          <Setter Property="Padding" Value="9,4" />
          <Setter Property="FontSize" Value="13" />
          <Setter Property="FontFamily" Value="Segoe UI" />
          <Setter Property="Foreground" Value="#FFEDEDED" />
          <Setter Property="Background" Value="#66303030" />
          <Setter Property="BorderBrush" Value="#668A6AB0" />
          <Setter Property="BorderThickness" Value="1" />
        </Style>
      </Border.Resources>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button x:Name="backBtn"
                  Content="Back"
                  ToolTip="Return to the main menu"
                  Click="btnBackClick" />
          <Button x:Name="backBtnTask"
                  Content="Show Task"
                  Visibility="Collapsed"
                  Click="showTaskClick" />
        </StackPanel>

        <Border Grid.Column="1"
                Margin="8,0,0,0"
                Padding="7,3"
                CornerRadius="7"
                Background="#33111111"
                BorderBrush="#228A6AB0"
                BorderThickness="1">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="Browse"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="#FFBFAFE0"
                       FontSize="12" />
            <StackPanel x:Name="nextPrevStackPanel"
                        Orientation="Horizontal">
              <Button x:Name="prevButton"
                      Content="Prev"
                      ToolTip="Move to the previous media item"
                      Click="clickPrev" />
              <Button x:Name="nextButton"
                      Content="Next"
                      ToolTip="Move to the next media item"
                      Click="clickNext" />
            </StackPanel>
            <Button x:Name="nextUntagged"
                    Content="Untagged"
                    ToolTip="Move to the next media item without tags"
                    MinWidth="96"
                    Click="clickUntagged" />
          </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Margin="8,0,0,0"
                Padding="7,3"
                CornerRadius="7"
                Background="#33111111"
                BorderBrush="#228A6AB0"
                BorderThickness="1">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="Bulk"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="#FFBFAFE0"
                       FontSize="12" />
            <Button x:Name="createGroup"
                    Content="Groups"
                    ToolTip="Save the current tags into a reusable group"
                    MinWidth="86"
                    Click="createGroup_Click" />
            <Button x:Name="bulkTaggingBtn"
                    Content="Tag"
                    ToolTip="Bulk tag selected media or folders"
                    MinWidth="82"
                    Click="bulkTagging_Click" />
            <Button x:Name="bulkMoveBtn"
                    Content="Move"
                    ToolTip="Move selected media while preserving tags"
                    MinWidth="82"
                    Click="bulkMove_Click" />
          </StackPanel>
        </Border>

        <TextBlock x:Name="selectionStatusText"
                   Grid.Column="3"
                   Margin="12,0"
                   VerticalAlignment="Center"
                   Foreground="#FFD6D6D6"
                   FontSize="13"
                   Text="Selected: 0" />

        <Border Grid.Column="4"
                Padding="7,3"
                CornerRadius="7"
                Background="#33111111"
                BorderBrush="#228A6AB0"
                BorderThickness="1">
          <StackPanel x:Name="typeStackPanel"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right">
            <TextBlock Text="View"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="#FFBFAFE0"
                       FontSize="12" />
            <Button x:Name="explorerViewBtn"
                    Content="Explorer"
                    ToolTip="Toggle explorer grid view"
                    MinWidth="98"
                    Click="explorerViewBtn_Click" />
            <Button x:Name="typeBtn"
                    Content="Image"
                    ToolTip="Switch between image and video view"
                    MinWidth="78"
                    Click="typeBtn_Click" />
            <Button x:Name="folderBtn"
                    Content="Folder"
                    IsTabStop="False"
                    ToolTip="Open the folder of the current media item"
                    MinWidth="78"
                    Click="folderBtn_Click" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <TextBox x:Name="copiedText"
             Grid.Row="3"
             Grid.ColumnSpan="3"
             Margin="0,10,0,0"
             Text="copied to clipboard"
             Foreground="#FF70E07A"
             BorderThickness="0"
             FontSize="18"
             Opacity="0"
             Background="#00FFFFFF"
             HorizontalAlignment="Center"
             VerticalAlignment="Top"
             TextDecorations="Underline"
             FontWeight="Bold"
             FontFamily="Times New Roman" />

    <Grid x:Name="OverlayHost"
          Grid.RowSpan="4"
          Grid.ColumnSpan="3"
          Panel.ZIndex="100"
          IsHitTestVisible="True" />
  </Grid>
</Page>
